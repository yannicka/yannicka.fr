{
  "scripts": {
    "serve": "concurrently --names \"eleventy,postcss\" --kill-others \"eleventy --serve\" \"postcss css/style.css --o public/assets/css/style.css --watch\"",
    "build": "ELEVENTY_PRODUCTION=true eleventy && NODE_ENV=production postcss css/style.css --o public/assets/css/style.css"
  },
  "devDependencies": {
    "@11ty/eleventy": "^0.12.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^3.1.3",
    "@tailwindcss/typography": "^0.5.0",
    "autoprefixer": "^10.4.2",
    "concurrently": "^7.0.0",
    "cssnano": "^5.0.14",
    "markdown-it": "^12.3.1",
    "markdown-it-anchor": "^8.4.1",
    "postcss": "^8.4.5",
    "postcss-cli": "^9.1.0",
    "postcss-import": "^14.0.2",
    "tailwindcss": "^3.0.12",
    "toml": "^3.0.0"
  }
}
